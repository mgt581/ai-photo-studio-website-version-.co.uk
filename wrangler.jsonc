{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "premuim-status",
  "main": "worker.js",
  "compatibility_date": "2026-04-08",
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "aiphotostudio.co.uk/__/auth/*",
      "zone_name": "aiphotostudio.co.uk"
    }
  ],
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
